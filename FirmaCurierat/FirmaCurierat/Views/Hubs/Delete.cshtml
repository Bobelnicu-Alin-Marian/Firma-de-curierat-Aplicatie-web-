@model FirmaCurierat.Models.Hub

@{
    ViewData["Title"] = "Șterge Hub";
}

<h3 class="text-danger">Ești sigur că vrei să ștergi acest sediu?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Oraș</dt>
        <dd class="col-sm-10">@Model.Oras</dd>
        <dt class="col-sm-2">Capacitate</dt>
        <dd class="col-sm-10">@Model.Capacitate</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id_hub" />
        <input type="submit" value="Confirmă Ștergerea" class="btn btn-danger" /> |
        <a asp-action="Index">Înapoi la listă</a>
    </form>
</div>