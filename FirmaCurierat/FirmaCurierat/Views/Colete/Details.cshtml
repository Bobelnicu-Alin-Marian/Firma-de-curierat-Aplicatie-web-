@model FirmaCurierat.Models.Colet

@{
    ViewData["Title"] = "Detalii Colet";
    var comanda = Model.Comanda;
}

<div style="max-width:900px; margin:40px auto; padding:0 20px;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:#d4edda;color:#155724;padding:15px;border-radius:8px;margin-bottom:25px;border:1px solid #c3e6cb;">
            <strong>✅</strong> @TempData["SuccessMessage"]
        </div>
    }

    @* ── Header AWB ── *@
    <div style="background:#212529;color:#fff;border-radius:12px 12px 0 0;padding:25px 30px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
        <div>
            <div style="font-size:12px;text-transform:uppercase;letter-spacing:1px;color:#aaa;">Număr AWB</div>
            <div style="font-size:28px;font-weight:900;letter-spacing:3px;color:#FFC107;">@Model.Awb</div>
        </div>
        <div style="text-align:right;">
            <span style="background:#FFC107;color:#212529;padding:6px 18px;border-radius:20px;font-weight:bold;font-size:14px;">
                @(comanda?.Status ?? "—")
            </span>
            <div style="font-size:12px;color:#aaa;margin-top:8px;">
                Cost livrare: <strong style="color:#FFC107;">@Model.CostLivrare.ToString("F2") RON</strong>
            </div>
        </div>
    </div>

    @* ── Corp principal ── *@
    <div style="background:#fff;border:1px solid #eee;border-top:none;border-radius:0 0 12px 12px;padding:30px;">

        @* ── Expeditor + Destinatar ── *@
        @if (comanda != null)
        {
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-bottom:30px;">

                <div style="background:#fffef5;border:1px solid #ffe58f;border-radius:8px;padding:20px;">
                    <div style="font-size:12px;text-transform:uppercase;font-weight:bold;color:#888;margin-bottom:12px;letter-spacing:1px;">
                        📤 Expeditor
                    </div>
                    @if (comanda.Expeditor != null)
                    {
                        <div style="font-size:17px;font-weight:700;color:#212529;margin-bottom:4px;">
                            @comanda.Expeditor.Prenume @comanda.Expeditor.Nume
                        </div>
                        @if (!string.IsNullOrWhiteSpace(comanda.Expeditor.Telefon))
                        {
                            <div style="color:#555;font-size:14px;">📞 @comanda.Expeditor.Telefon</div>
                        }
                    }
                    @if (comanda.AdresaRidicare != null)
                    {
                        <div style="margin-top:10px;padding-top:10px;border-top:1px dashed #eee;font-size:13px;color:#666;">
                            <div style="font-weight:bold;color:#444;margin-bottom:4px;">📍 Adresă ridicare</div>
                            <div>@comanda.AdresaRidicare.Strada @comanda.AdresaRidicare.Numar</div>
                            <div>@comanda.AdresaRidicare.Localitate, @comanda.AdresaRidicare.Judet</div>
                            <div>@comanda.AdresaRidicare.Tara</div>
                        </div>
                    }
                </div>

                <div style="background:#f0f8ff;border:1px solid #b8daff;border-radius:8px;padding:20px;">
                    <div style="font-size:12px;text-transform:uppercase;font-weight:bold;color:#888;margin-bottom:12px;letter-spacing:1px;">
                        📥 Destinatar
                    </div>
                    @if (comanda.Destinatar != null)
                    {
                        <div style="font-size:17px;font-weight:700;color:#212529;margin-bottom:4px;">
                            @comanda.Destinatar.Prenume @comanda.Destinatar.Nume
                        </div>
                        @if (!string.IsNullOrWhiteSpace(comanda.Destinatar.Telefon))
                        {
                            <div style="color:#555;font-size:14px;">📞 @comanda.Destinatar.Telefon</div>
                        }
                    }
                    @if (comanda.AdresaLivrare != null)
                    {
                        <div style="margin-top:10px;padding-top:10px;border-top:1px dashed #eee;font-size:13px;color:#666;">
                            <div style="font-weight:bold;color:#444;margin-bottom:4px;">📍 Adresă livrare</div>
                            <div>@comanda.AdresaLivrare.Strada @comanda.AdresaLivrare.Numar</div>
                            <div>@comanda.AdresaLivrare.Localitate, @comanda.AdresaLivrare.Judet</div>
                            <div>@comanda.AdresaLivrare.Tara</div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Detalii colet ── *@
        <div style="background:#f8f9fa;border-radius:8px;padding:20px;margin-bottom:25px;">
            <div style="font-size:12px;text-transform:uppercase;font-weight:bold;color:#888;margin-bottom:15px;letter-spacing:1px;">📦 Detalii Colet</div>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:15px;">
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Tip</div>
                    <div style="font-weight:700;color:#333;">@Model.Tip</div>
                </div>
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Dimensiune</div>
                    <div style="font-weight:700;color:#333;">@(Model.Dimensiune ?? "—")</div>
                </div>
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Greutate</div>
                    <div style="font-weight:700;color:#333;">@Model.Greutate kg</div>
                </div>
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Zonă livrare</div>
                    <div style="font-weight:700;color:#333;">@Model.ZonaLivrare</div>
                </div>
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Valoare declarată</div>
                    <div style="font-weight:700;color:#333;">@Model.Pret.ToString("F2") RON</div>
                </div>
                <div>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;">Cost livrare</div>
                    <div style="font-weight:700;color:#FFC107;font-size:18px;">@Model.CostLivrare.ToString("F2") RON</div>
                </div>
            </div>
        </div>

        @* ── Istoric status ── *@
        @if (Model.Statusuri != null && Model.Statusuri.Any())
        {
            <div>
                <div style="font-size:12px;text-transform:uppercase;font-weight:bold;color:#888;margin-bottom:15px;letter-spacing:1px;">🕓 Istoric Status</div>
                <div class="timeline">
                    @foreach (var s in Model.Statusuri.OrderByDescending(x => x.Data_actualizare))
                    {
                        <div class="timeline-step active">
                            <div class="step-icon">📦</div>
                            <div class="step-info">
                                <h4>@s.Denumire</h4>
                                <p>@s.Locatie — @s.Data_actualizare.ToString("dd MMM yyyy, HH:mm")</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Acțiuni ── *@
        <div style="margin-top:25px;padding-top:20px;border-top:1px solid #eee;display:flex;gap:15px;flex-wrap:wrap;">
            <a asp-action="Edit" asp-route-id="@Model.Id_colet"
               style="padding:10px 25px;background:#212529;color:#FFC107;border-radius:6px;text-decoration:none;font-weight:bold;">
                ✏️ Editează
            </a>
            <a asp-action="Index"
               style="padding:10px 25px;background:#f8f9fa;color:#333;border-radius:6px;text-decoration:none;font-weight:bold;border:1px solid #ddd;">
                ← Lista colete
            </a>
        </div>
    </div>
</div>
