@model FirmaCurierat.Models.Colet

<main>
    <section class="shipping-section">
        <h2>Editează Coletul</h2>
        <p class="subtitle">Modifică detaliile coletului existent în sistem.</p>
        
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" style="color:red;"></div>
            
            <input type="hidden" asp-for="Id_colet" />

            <fieldset class="parcel-details">
                <legend>Informații Colet</legend>
                
                <div class="form-group">
                    <label>Număr AWB (Nu poate fi modificat)</label>
                    <input asp-for="Awb" class="form-control" readonly style="background-color: #eee; cursor: not-allowed;" />
                </div>
                
                <div class="form-group" style="margin-top: 15px;">
                    <label>Dimensiune Colet</label>
                    <select asp-for="Dimensiune" class="form-control">
                        <option value="S">S (Plic / Cutie mică)</option>
                        <option value="M">M (Cutie medie - Standard)</option>
                        <option value="L">L (Cutie mare / Voluminos)</option>
                        <option value="XL">XL (Palet / Agabaritic)</option>
                    </select>
                </div>

                <div class="form-group-inline" style="display:flex; gap:20px; margin-top:15px;">
                    <div class="form-group" style="flex:1;">
                        <label>Greutate (kg)</label>
                        <input asp-for="Greutate" type="number" step="0.01" required>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Preț (RON)</label>
                        <input asp-for="Pret" type="number" step="0.01" required>
                    </div>
                </div>

                <div class="form-group" style="margin-top:15px;">
                    <label>Tip trimitere</label>
                    <select asp-for="Tip">
                        <option value="Plic">Plic</option>
                        <option value="Standard">Colet Standard</option>
                        <option value="Fragil">Colet Fragil</option>
                        <option value="Voluminos">Colet Voluminos</option>
                    </select>
                </div>

                <input type="hidden" asp-for="Id_comanda" />
            </fieldset>

            <div style="margin-top: 20px; display: flex; gap: 10px;">
                <button type="submit" class="btn-submit">Salvează Modificările</button>
                <a asp-action="Index" style="text-decoration: none; padding: 10px 20px; background: #666; color: white; border-radius: 5px;">Anulează</a>
            </div>
        </form>
    </section>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}