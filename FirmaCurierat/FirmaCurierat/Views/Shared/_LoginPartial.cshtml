@using Microsoft.AspNetCore.Identity
@using FirmaCurierat.Models

@inject SignInManager<ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    <a asp-controller="Profil" asp-action="Index" class="btn-profil">Profilul Meu</a>
    <form asp-area="Identity" asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
          style="display:inline; margin-left:10px;">
        <button type="submit" class="btn-profil">Deconectare</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="btn-profil">Autentificare</a>
    <a asp-area="Identity" asp-page="/Account/Register" class="btn-profil" style="margin-left:10px;">Înregistrare</a>
}
