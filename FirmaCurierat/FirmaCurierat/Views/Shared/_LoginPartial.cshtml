@using Microsoft.AspNetCore.Identity
@using FirmaCurierat.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="nav-links" style="margin: 0; padding: 0; display: flex; align-items: center; list-style: none; gap: 15px;">
    @if (SignInManager.IsSignedIn(User))
    {
        <li>
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn-profil" style="background: none; color: #333;">
                Salut, @User.Identity?.Name!
            </a>
        </li>
        <li>
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" style="display:inline;">
                <button type="submit" class="btn-profil" style="border: none; cursor: pointer;">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn-profil" style="background: none; color: #333;">Register</a>
        </li>
        <li>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-profil">Login</a>
        </li>
    }
</ul>