@model FirmaCurierat.Models.Contact

@{
    ViewData["Title"] = "Șterge Contact";
}

<div style="max-width: 600px; margin: 50px auto; padding: 40px; background-color: #ffffff; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-top: 5px solid #dc3545; text-align: center;">
    <h2 style="margin-top: 0; color: #dc3545;">Ești sigur că vrei să ștergi?</h2>
    <p style="color: #666; margin-bottom: 30px;">Această acțiune este permanentă și va elimina metoda de contact de pe site.</p>

    <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 30px; text-align: left;">
        <p style="margin: 0 0 10px 0; font-size: 24px;">@Model.Metoda</strong></p>
        <p style="margin: 0 0 5px 0; color: #555;">Informație: @Model.Valoare</p>
        <p style="margin: 0; color: #888; font-size: 14px;">Detalii extra: @Model.Detalii</p>
    </div>

    <form asp-action="Delete" style="display: flex; justify-content: space-between; align-items: center;">
        <input type="hidden" asp-for="Id_contact" />
        <a asp-action="Index" style="color: #6c757d; text-decoration: none; font-weight: bold;">← Anulează</a>
        <button type="submit" style="background-color: #dc3545; color: #fff; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; font-size: 16px; cursor: pointer;">
            🗑️ Da, Șterge
        </button>
    </form>
</div>