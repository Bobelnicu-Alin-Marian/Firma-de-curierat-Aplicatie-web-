@model IEnumerable<FirmaCurierat.Models.Tarif>

@{
    ViewData["Title"] = "Tarife Standard";
}

<style>
    /* Stiluri generale */
    .tarife-wrapper {
        max-width: 1000px;
        margin: auto;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    .header-section {
        text-align: center;
        margin: 40px 0 30px;
    }

    .header-section h1 {
        font-weight: 800;
        color: #212529;
        margin-bottom: 10px;
    }

    .header-section p {
        color: #6c757d;
        font-size: 1.1rem;
    }

    /* Buton Adaugare */
    .btn-add {
        background-color: #212529;
        color: #FFC107;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: bold;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .btn-add:hover {
        background-color: #FFC107;
        color: #212529;
        text-decoration: none;
        transform: translateY(-2px);
    }

    /* Stiluri Tabel */
    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 25px;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 0;
    }

    .custom-table th {
        background-color: #FFC107;
        color: #212529;
        padding: 18px 15px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 0.5px;
        border: none;
    }

    .custom-table td {
        padding: 16px 15px;
        vertical-align: middle;
        color: #495057;
        border-bottom: 1px solid #f8f9fa;
        font-weight: 500;
    }

    .custom-table tbody tr {
        transition: background-color 0.2s ease;
    }

    .custom-table tbody tr:hover {
        background-color: #fffdf5;
    }

    /* Butoane Actiuni Tabel */
    .action-btn {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        margin-left: 5px;
        display: inline-block;
    }

    .btn-edit { background: #e6f2ff; color: #0d6efd; }
    .btn-edit:hover { background: #0d6efd; color: white; }

    .btn-details { background: #e0f8e9; color: #198754; }
    .btn-details:hover { background: #198754; color: white; }

    .btn-delete { background: #fde8e9; color: #dc3545; }
    .btn-delete:hover { background: #dc3545; color: white; }

    /* Nota informativa */
    .info-note {
        padding: 15px 20px;
        background-color: #f8f9fa;
        border-left: 5px solid #FFC107;
        border-radius: 0 8px 8px 0;
        font-size: 14px;
        color: #555;
    }

    /* Calculator Widget */
    .calculator-widget {
        background: linear-gradient(145deg, #ffffff, #fdfbf5);
        border: 2px solid #FFC107;
        border-radius: 12px;
        padding: 35px;
        margin-top: 40px;
        margin-bottom: 60px;
        box-shadow: 0 10px 30px rgba(255, 193, 7, 0.1);
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
        color: #333;
    }

    .form-input {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #ced4da;
        border-radius: 8px;
        font-size: 15px;
        transition: border-color 0.3s;
    }

    .form-input:focus {
        border-color: #FFC107;
        outline: none;
        box-shadow: 0 0 0 3px rgba(255, 193, 7, 0.2);
    }

    .btn-calculate {
        width: 100%;
        padding: 13px;
        background-color: #212529;
        color: #FFC107;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-calculate:hover {
        background-color: #343a40;
        transform: translateY(-2px);
    }

    .result-box {
        display: none;
        margin-top: 30px;
        text-align: center;
        padding-top: 25px;
        border-top: 2px dashed #f0e6c8;
    }
</style>

<div class="tarife-wrapper">
    
    <div class="header-section">
        <h1>Tarife Standard</h1>
        <p>Prețuri transparente, fără costuri ascunse. Alege opțiunea potrivită pentru tine.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div style="text-align: right; margin-bottom: 20px;">
            <a asp-action="Create" class="btn-add">➕ Adaugă Tarif Nou</a>
        </div>
    }

    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="text-align: left;">Tip / Greutate Colet</th>
                    <th style="text-align: center;">Local <br><small>(București/Ilfov)</small></th>
                    <th style="text-align: center;">Național <br><small>(România)</small></th>
                    <th style="text-align: center;">Internațional <br><small>(UE)</small></th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th style="text-align: right; padding-right: 20px;">Acțiuni</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: bold; color: #212529;">@item.CategorieGreutate</td>
                        <td style="text-align: center; font-weight: 600;">@item.PretLocal <small class="text-muted">RON</small></td>
                        <td style="text-align: center; font-weight: 600;">@item.PretNational <small class="text-muted">RON</small></td>
                        <td style="text-align: center; font-weight: 600;">@item.PretInternational <small class="text-muted">RON</small></td>
                        
                        <td style="text-align: right;">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id_tarif" class="action-btn btn-edit">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id_tarif" class="action-btn btn-details">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id_tarif" class="action-btn btn-delete">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="info-note">
        <strong>Notă:</strong> Tarifele includ TVA. Pentru coletele asigurate cu plata ramburs, se percepe o taxă suplimentară din valoarea declarată a coletului.
    </div>

    <div class="calculator-widget">
        <h4 style="margin-top:0; margin-bottom:5px; color:#212529; font-weight:800; font-size:22px;">🧮 Calculator Estimare Cost</h4>
        <p style="color:#6c757d; font-size:15px; margin-bottom:30px;">
            Selectează tipul coletului și zona de destinație pentru a obține prețul exact din grila noastră de tarife.
        </p>

        <div style="display:flex; gap:20px; flex-wrap:wrap; align-items:flex-end;">

            <div style="flex:1; min-width:220px;">
                <label class="form-label">📦 Tip / Categorie Colet</label>
                <select id="categorie" class="form-input">
                    <option value="">— Selectează categoria —</option>
                </select>
            </div>

            <div style="flex:1; min-width:220px;">
                <label class="form-label">📍 Zonă Destinație</label>
                <select id="zona" class="form-input">
                    <option value="">— Selectează zona —</option>
                    <option value="local">🏙️ Local (București / Ilfov)</option>
                    <option value="national">🇷🇴 Național (România)</option>
                    <option value="international">🌍 Internațional (UE)</option>
                </select>
            </div>

            <div style="flex:0 0 auto; min-width:180px;">
                <button type="button" onclick="calculeazaCost()" class="btn-calculate">
                    CALCULEAZĂ
                </button>
            </div>
        </div>

        <div id="rezultat-box" class="result-box">
            <div style="display:flex; justify-content:center; gap:40px; flex-wrap:wrap; margin-bottom:20px;">

                <div style="text-align:center;">
                    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1px; color:#999; margin-bottom:6px;">Cost Expediere</div>
                    <div style="font-size:42px; font-weight:900; color:#d99a00; line-height:1;">
                        <span id="pret-final">0</span>
                        <span style="font-size:18px; font-weight:600; color:#555;">RON</span>
                    </div>
                    <div style="font-size:12px; color:#aaa; margin-top:4px;">TVA inclus</div>
                </div>

                <div style="text-align:center;">
                    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1px; color:#999; margin-bottom:6px;">Timp Estimat Livrare</div>
                    <div style="font-size:28px; font-weight:800; color:#212529; line-height:1;" id="timp-livrare">—</div>
                    <div style="font-size:12px; color:#aaa; margin-top:4px;">zile lucrătoare</div>
                </div>

            </div>

            <div id="detalii-tarif" style="background:#f8f9fa; border-radius:8px; padding:14px 20px; font-size:14px; color:#555; text-align:left; margin-bottom:16px;"></div>

            <a asp-controller="Colete" asp-action="Create"
               style="display:inline-block; padding:12px 35px; background:#212529; color:#FFC107; border-radius:8px; font-weight:bold; text-decoration:none; font-size:15px; transition:background 0.3s;"
               onmouseover="this.style.background='#343a40'" onmouseout="this.style.background='#212529'">
                Creează Expediere →
            </a>

            <p style="margin:12px 0 0; color:#aaa; font-size:12px;">
                * Prețul afișat provine direct din grila de tarife. Costul final poate varia în funcție de servicii suplimentare (asigurare, ramburs etc.).
            </p>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Tarifele din baza de date, serializate direct in pagina
        const tarife = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                Model.Select(t => new {
                    categorie  = t.CategorieGreutate,
                    local      = t.PretLocal,
                    national   = t.PretNational,
                    international = t.PretInternational
                })
            )
        );

        // Populam dropdown-ul cu categoriile din DB
        const selectCategorie = document.getElementById('categorie');
        tarife.forEach(t => {
            const opt = document.createElement('option');
            opt.value = t.categorie;
            opt.textContent = t.categorie;
            selectCategorie.appendChild(opt);
        });

        const timpLivrare = {
            local:         '1',
            national:      '2 – 3',
            international: '5 – 10'
        };

        const zonaLabel = {
            local:         'Local (București / Ilfov)',
            national:      'Național (România)',
            international: 'Internațional (UE)'
        };

        function calculeazaCost() {
            const categorieVal = document.getElementById('categorie').value;
            const zonaVal      = document.getElementById('zona').value;

            if (!categorieVal) {
                alert('Te rugăm să selectezi tipul / categoria coletului!');
                return;
            }
            if (!zonaVal) {
                alert('Te rugăm să selectezi zona de destinație!');
                return;
            }

            const tarif = tarife.find(t => t.categorie === categorieVal);
            if (!tarif) {
                alert('Tariful pentru această categorie nu a fost găsit.');
                return;
            }

            const pret = zonaVal === 'local'
                ? tarif.local
                : zonaVal === 'national'
                    ? tarif.national
                    : tarif.international;

            document.getElementById('pret-final').textContent  = parseFloat(pret).toFixed(2);
            document.getElementById('timp-livrare').textContent = timpLivrare[zonaVal];

            document.getElementById('detalii-tarif').innerHTML =
                `<strong>Categorie:</strong> ${tarif.categorie} &nbsp;|&nbsp; ` +
                `<strong>Zonă:</strong> ${zonaLabel[zonaVal]} &nbsp;|&nbsp; ` +
                `<strong>Preț Local:</strong> ${parseFloat(tarif.local).toFixed(2)} RON &nbsp;|&nbsp; ` +
                `<strong>Preț Național:</strong> ${parseFloat(tarif.national).toFixed(2)} RON &nbsp;|&nbsp; ` +
                `<strong>Preț Internațional:</strong> ${parseFloat(tarif.international).toFixed(2)} RON`;

            document.getElementById('rezultat-box').style.display = 'block';
        }
    </script>
}