@model FirmaCurierat.Models.Tarif

<main>
    <section class="shipping-section">
        <h2>Editează Tariful</h2>
        <input type="hidden" asp-for="Id_tarif" />

        <form asp-action="Edit" method="post">
            <fieldset class="parcel-details">
                <legend>Actualizare Prețuri: @Model.CategorieGreutate</legend>
                <div class="form-group">
                    <label asp-for="CategorieGreutate">Denumire Categorie</label>
                    <input asp-for="CategorieGreutate" required>
                </div>
                <div class="form-group-inline" style="display:flex; gap:15px; margin-top:20px;">
                    <div style="flex:1;"><label>Preț Local</label><input asp-for="PretLocal" type="number" step="0.01"></div>
                    <div style="flex:1;"><label>Preț Național</label><input asp-for="PretNational" type="number" step="0.01"></div>
                    <div style="flex:1;"><label>Preț Internațional</label><input asp-for="PretInternational" type="number" step="0.01"></div>
                </div>
            </fieldset>
            <button type="submit" class="btn-submit" style="margin-top:20px;">Actualizează</button>
            <a asp-action="Index">Înapoi</a>
        </form>
    </section>
</main>