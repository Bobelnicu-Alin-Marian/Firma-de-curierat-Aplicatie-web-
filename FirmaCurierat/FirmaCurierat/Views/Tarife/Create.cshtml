@model FirmaCurierat.Models.Tarif

<main>
    <section class="shipping-section">
        <h2>Adaugă Categorie de Tarif</h2>
        <p class="subtitle">Introdu noile praguri de preț pentru serviciile de curierat.</p>

        <form asp-action="Create" method="post">
            <fieldset class="parcel-details">
                <legend>Configurare Prețuri</legend>
                
               
                <div class="form-group" style="margin-top:15px;">
                    <label>Tip Colet</label>
                    <select asp-for="CategorieGreutate">
                        <option value="Plic">Plic (max 1kg)</option>
                        <option value="Standard" selected>Colet Standard</option>
                        <option value="Fragil">Colet Fragil</option>
                        <option value="Voluminos">Colet Voluminos</option>
                    </select>
                </div>

                <div class="form-group-inline" style="display:flex; gap:15px; margin-top:20px;">
                    <div class="form-group" style="flex:1;">
                        <label asp-for="PretLocal">Preț Local (RON)</label>
                        <input asp-for="PretLocal" type="number" step="0.01" required>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label asp-for="PretNational">Preț Național (RON)</label>
                        <input asp-for="PretNational" type="number" step="0.01" required>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label asp-for="PretInternational">Preț Internațional (RON)</label>
                        <input asp-for="PretInternational" type="number" step="0.01" required>
                    </div>
                </div>
            </fieldset>

            <div style="margin-top:25px; display:flex; gap:15px; align-items:center;">
                <button type="submit" class="btn-submit">Salvează Tariful</button>
                <a asp-action="Index" style="color:#666;">Anulează</a>
            </div>
        </form>
    </section>
</main>